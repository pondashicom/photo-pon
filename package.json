{
  "name": "photo-pon",
  "version": "0.2.0",
  "license": "AGPL-3.0-or-later",
  "description": "Batch portrait crop prototype for Windows",
  "main": "src/main.js",
  "type": "commonjs",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --win nsis"
  },
  "build": {
    "appId": "com.photopon.app",
    "productName": "PHOTO-PON",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "asar": false,
    "win": {
      "icon": "assets/icons/photo-pon-icon-transparent.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "artifactName": "${productName}-Setup-${version}.${ext}"
    }
  },
  "dependencies": {
    "@imgly/background-removal-node": "^1.4.5",
    "@vladmandic/human": "^3.3.6",
    "electron-store": "^10.0.1",
    "sharp": "^0.34.1"
  },
  "devDependencies": {
    "electron": "^36.0.0",
    "electron-builder": "^26.8.1"
  }
}